# Backend environment variables
# Copy this to .env and update values for production

# Database
DATABASE_URL=sqlite+aiosqlite:///./rentflow.db

# Redis (uncomment for production)
# REDIS_URL=redis://localhost:6379/0

# Security — CHANGE THESE IN PRODUCTION
SECRET_KEY=change-me-in-production-use-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:3000"]

# Frontend URL — used for invitation links (defaults to https://DOMAIN in prod)
# FRONTEND_URL=https://rentflow.dpdns.org

# Debug mode
DEBUG=true
